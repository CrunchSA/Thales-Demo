# CipherTrust Manager Connection
CM_URL=https://<your-cm-ip-or-fqdn>
CM_CLIENT_ID=<your-crdp-client-id>
CM_CLIENT_SECRET=<your-crdp-client-secret>
CM_TOKEN=<your-crdp-auth-token>

# CRDP Policies
CRDP_EMAIL_POLICY=email-policy
CRDP_CC_POLICY=credit-card-policy

# CSM (Secrets Management) Configuration
CSM_ACCESS_ID=<your-akeyless-access-id>
CSM_ACCESS_KEY=<your-akeyless-access-key>
CSM_DB_PASSWORD_PATH=/path/to/mysql/password

# MySQL Configuration
DB_HOST=mysql-service
DB_USER=demo_user
DB_NAME=thales_demo
# DB_PASSWORD will be fetched from CSM at runtime
