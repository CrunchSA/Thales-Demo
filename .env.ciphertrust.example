# CipherTrust API Configuration

# CipherTrust Server URL
# Example: https://ciphertrust-server.example.com:5696
CIPHERTRUST_URL=https://your-ciphertrust-server.com

# CipherTrust credentials
CIPHERTRUST_USERNAME=your-username
CIPHERTRUST_PASSWORD=your-password

# Optional: Domain/partition name (defaults to "default")
CIPHERTRUST_DOMAIN=default
